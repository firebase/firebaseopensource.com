  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck .",
    "deploy": "npm run generate && npx -y firebase-tools --project=default deploy",
    "deploy:hosting": "npx -y firebase-tools --project=default deploy --only hosting",
    "shadcn:copy": "npx @firebase-oss/ui-shadcn@beta copy --outDir=.output/public/r"
  },
  "devDependencies": {
    "@docsearch/css": "^4.6.3",
    "@docsearch/js": "^4.6.3",
    "@nuxt/eslint": "^1.16.0",
    "@nuxtjs/sitemap": "^8.2.1",
    "date-fns": "^4.4.0",
    "eslint": "^10.5.0",
    "firebase": "^12.15.0",
    "isomorphic-dompurify": "^3.18.0",
    "nuxt": "^4.4.8",
    "sass": "^1.101.0",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "overrides": {
    "esbuild": "~0.25.0"
  }
}
